# Dependencies
node_modules
.pnp
.pnp.js

# Lockfile is intentionally untracked: macOS-generated lockfiles include
# only platform-local optional deps (npm/cli#4828), which breaks Linux
# runners on CI/Netlify. Each environment regenerates from package.json.
# See docs/issues.md #14b.
package-lock.json

# Nuxt build output
.nuxt
.output
.data
.vercel
.netlify
dist

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment — NEVER commit secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
Thumbs.db

# Test / coverage
coverage
*.lcov
.nyc_output

# Local Supabase artifacts
supabase/.temp
supabase/.branches

# Security scan output
gitleaks-report.json
trivy-report.json
*.sarif
