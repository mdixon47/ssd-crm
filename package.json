{
  "name": "ssd-consulting-crm",
  "version": "1.0.0",
  "description": "SSD Consulting — Paid Acquisition CRM with AI Agents",
  "private": true,
  "scripts": {
    "dev": "TMPDIR=/tmp nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "node -e \"if(!process.env.CI)require('child_process').execSync('nuxt prepare',{stdio:'inherit'})\"",
    "lint": "eslint .",
    "typecheck": "NODE_OPTIONS='--max-old-space-size=8192' nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.0.0 <25",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@nuxtjs/supabase": "^2.0.9",
    "@pinia/nuxt": "^0.11.3",
    "@supabase/supabase-js": "^2.45.0",
    "chart.js": "^4.4.4",
    "nuxt": "^3.16.2",
    "pinia": "^3.0.2",
    "resend": "^6.12.4",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxtjs/tailwindcss": "^6.12.2",
    "@types/node": "^26.0.0",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  },
  "overrides": {
    "zod": "$zod",
    "esbuild": ">=0.28.1"
  }
}
