# ============================================================
# SSD Consulting CRM — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Anthropic (Claude AI Agents)
# Get your key at: https://console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# Supabase (Database)
# Get these from: https://app.supabase.com/project/_/settings/api
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Google Ads MCP (optional — mock data used if not set)
# Docs: https://developers.google.com/google-ads/api
# ------------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ------------------------------------------------------------
# Meta (Facebook/Instagram) Ads MCP (optional)
# Docs: https://developers.facebook.com/docs/marketing-apis
# ------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_

# ------------------------------------------------------------
# LinkedIn Ads MCP (optional)
# Docs: https://learn.microsoft.com/en-us/linkedin/marketing
# ------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=

# ------------------------------------------------------------
# Google Analytics 4 (Website analytics — optional; mock data used if unset)
# Reads traffic/acquisition/conversion data via the GA4 Data API.
# Setup:
#   1. GA4 Admin → Property Settings → copy the numeric Property ID.
#   2. Google Cloud Console → create a Service Account → create a JSON key,
#      then enable the "Google Analytics Data API" for that project.
#   3. GA4 Admin → Property Access Management → add the service-account email
#      (client_email) as a "Viewer". Then paste its email + private key below.
# Docs: https://developers.google.com/analytics/devguides/reporting/data/v1
# ------------------------------------------------------------
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
# Use the JSON key's "private_key" value (the long PEM block, NOT private_key_id),
# on one line in double quotes with the literal \n escapes:
GA4_PRIVATE_KEY=

# ------------------------------------------------------------
# Resend (Email Sending)
# Get your key at: https://resend.com/api-keys
# Verify your domain at: https://resend.com/domains
# ------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=you@yourdomain.com

# ------------------------------------------------------------
# Server-to-server secrets
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
# NUXT_A2A_SECRET:   Bearer token for /api/a2a/* machine-to-machine callers
# NUXT_CRON_SECRET:  Bearer token for /api/cron/* scheduled function calls
# Also set NUXT_CRON_SECRET and APP_URL as GitHub Actions secrets for the
# cron-publish.yml workflow.
# ------------------------------------------------------------
NUXT_A2A_SECRET=
NUXT_CRON_SECRET=

# ------------------------------------------------------------
# AI Media Workflow — Marketing Video (optional)
# Used ONLY by build-time scripts in marketing/video/ to generate/enhance
# video assets (voiceover, captions, B-roll) BEFORE rendering with Remotion.
# Leave blank to author scripts manually. See marketing/video/video.md.
# NOTE: never reference these inside Remotion src/** — they'd be bundled into output.
# ------------------------------------------------------------
ELEVENLABS_API_KEY=        # AI voiceover/narration — https://elevenlabs.io
OPENAI_API_KEY=            # alt script gen / Whisper auto-captions / TTS — https://platform.openai.com
REPLICATE_API_TOKEN=       # AI B-roll / background image generation — https://replicate.com
PEXELS_API_KEY=            # free stock footage & photos — https://www.pexels.com/api

# ------------------------------------------------------------
# App Config
# ------------------------------------------------------------
MCP_BASE_URL=/api/mcp
NODE_ENV=development
